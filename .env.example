# Database
DATABASE_URL=postgresql://user:password@db:5432/csvtoxml
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=csvtoxml

# Redis
REDIS_URL=redis://redis:6379

# Authentication
NEXTAUTH_SECRET=generate-a-random-secret-here

# Worker service-to-service auth (SEC-1)
# Shared secret the web app sends and the worker requires on every call.
# Must be identical for both services. Generate with: openssl rand -hex 32
WORKER_AUTH_TOKEN=generate-a-random-secret-here

# Job durability (ARCH-1) — optional; sensible defaults apply if unset.
# CONVERSION_TIMEOUT_MS: how long the web waits for the worker's /convert before
#   aborting (default 1800000 = 30 min; raised from the old 5 min so long but
#   valid conversions complete instead of being marked error).
# REAP_DEADLINE_MS: a job stuck in "converting" longer than this is failed by the
#   reaper (default 2700000 = 45 min). MUST be greater than CONVERSION_TIMEOUT_MS.
CONVERSION_TIMEOUT_MS=1800000
REAP_DEADLINE_MS=2700000
