# Database
DATABASE_URL=postgresql://user:password@db:5432/csvtoxml
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=csvtoxml

# Redis
REDIS_URL=redis://redis:6379

# Authentication
NEXTAUTH_SECRET=generate-a-random-secret-here

# Worker service-to-service auth (SEC-1)
# Shared secret the web app sends and the worker requires on every call.
# Must be identical for both services. Generate with: openssl rand -hex 32
WORKER_AUTH_TOKEN=generate-a-random-secret-here

# Job durability (ARCH-1) — optional; sensible defaults apply if unset.
# The durable queue uses three interlocking timeouts; keep the ordering
#   CONVERSION_TIMEOUT_MS < VISIBILITY_TIMEOUT_MS < REAP_DEADLINE_MS.
# CONVERSION_TIMEOUT_MS: how long the web waits for one /convert attempt before
#   aborting it (default 1800000 = 30 min).
# VISIBILITY_TIMEOUT_MS: a claimed job not finished within this is treated as
#   abandoned (its consumer died) and re-queued by the sweep (default 2400000 = 40 min).
# REAP_DEADLINE_MS: backstop — a job stuck queued/converting longer than this is
#   failed (default 3600000 = 60 min).
# JOB_MAX_ATTEMPTS: max conversion attempts before dead-lettering to "error" (default 3).
CONVERSION_TIMEOUT_MS=1800000
VISIBILITY_TIMEOUT_MS=2400000
REAP_DEADLINE_MS=3600000
JOB_MAX_ATTEMPTS=3

# Input size cap (ARCH-5) — optional; max accepted upload in bytes (default
# 52428800 = 50 MB). Enforced at upload and re-checked server-side before each
# worker call. After ARCH-4 the web↔worker bodies carry only paths (not file
# content), so this cap — not the request body — is what bounds conversion memory.
MAX_UPLOAD_BYTES=52428800

# Conversion concurrency is 1 by design: a single sequential queue consumer
# (apps/web/src/lib/job-consumer.ts) runs one job at a time. To raise throughput,
# run more web instances — consumers claim jobs atomically (BLMOVE + guarded
# updateMany), so multiple consumers share the queue without double-running a job.
