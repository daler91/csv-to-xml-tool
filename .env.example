# Database
DATABASE_URL=postgresql://user:password@db:5432/csvtoxml
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=csvtoxml

# Redis
REDIS_URL=redis://redis:6379

# Authentication
NEXTAUTH_SECRET=generate-a-random-secret-here

# Worker service-to-service auth (SEC-1)
# Shared secret the web app sends and the worker requires on every call.
# Must be identical for both services. Generate with: openssl rand -hex 32
WORKER_AUTH_TOKEN=generate-a-random-secret-here
