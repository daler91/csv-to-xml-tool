DATABASE_URL="postgresql://user:pass@localhost:5432/csvtoxml"
NEXTAUTH_SECRET="generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"
WORKER_URL="http://localhost:8000"
# Shared secret for worker auth (SEC-1) — must match the worker's WORKER_AUTH_TOKEN.
WORKER_AUTH_TOKEN="generate-with-openssl-rand-hex-32"
DATA_DIR="/data"
# Redis — used for the durable job queue (ARCH-1) and rate limiting.
REDIS_URL="redis://localhost:6379"
# Job durability (ARCH-1, optional; defaults shown).
# Keep the ordering CONVERSION_TIMEOUT_MS < VISIBILITY_TIMEOUT_MS < REAP_DEADLINE_MS.
CONVERSION_TIMEOUT_MS="1800000"
VISIBILITY_TIMEOUT_MS="2400000"
REAP_DEADLINE_MS="3600000"
JOB_MAX_ATTEMPTS="3"
# Max accepted upload size in bytes (ARCH-5; default 52428800 = 50 MB).
MAX_UPLOAD_BYTES="52428800"
# Conversion concurrency is 1 (single sequential queue consumer, job-consumer.ts);
# scale out by running more web instances — consumers claim jobs atomically.
